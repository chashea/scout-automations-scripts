{
  "name": "read-email-filing-rules",
  "enabled": true,
  "schedule": {
    "type": "cron",
    "expression": "0 23 * * 0",
    "timezone": "America/New_York"
  },
  "defaultAction": "none",
  "rules": [
    {
      "id": "st-of-ct-routing",
      "enabled": true,
      "priority": 1,
      "conditions": {
        "isRead": true,
        "isPinned": false,
        "from": {
          "domains": ["@ct.gov"]
        }
      },
      "action": {
        "type": "move",
        "destinationFolder": "Inbox/Accounts/St of CT"
      }
    },
    {
      "id": "pannynj-routing",
      "enabled": true,
      "priority": 2,
      "conditions": {
        "isRead": true,
        "isPinned": false,
        "from": {
          "domains": ["@panynj.gov)"]
        }
      },
      "action": {
        "type": "move",
        "destinationFolder": "Inbox/Accounts/PANNYNJ"
      }
    },
    {
      "id": "st-of-vt-routing",
      "enabled": true,
      "priority": 3,
      "conditions": {
        "isRead": true,
        "isPinned": false,
        "from": {
          "domains": ["@vermont.com"]
        }
      },
      "action": {
        "type": "move",
        "destinationFolder": "Inbox/Accounts/St of VT"
      }
    },
    {
      "id": "ne-slg-team-routing",
      "enabled": true,
      "priority": 4,
      "conditions": {
        "isRead": true,
        "isPinned": false,
        "from": {
          "emails": [
            "ericjacobsen@microsoft.com",
            "brandonbrin@microsoft.com",
            "paulmccabe@microsoft.com",
            "Sam.Raymond@microsoft.com",
            "saraymon@microsoft.com",
            "yschwartz@microsoft.com"
          ]
        }
      },
      "action": {
        "type": "move",
        "destinationFolder": "Inbox/NE SLG Team"
      }
    },
    {
      "id": "ne-edu-team-routing",
      "enabled": true,
      "priority": 5,
      "conditions": {
        "isRead": true,
        "isPinned": false,
        "from": {
          "emails": [
            "joshuaklein@microsoft.com",
            "abrockwell@microsoft.com",
            "Stephon.Bowden@microsoft.com",
            "timfairlie@microsoft.com",
            "Baileythomas@microsoft.com"
          ]
        }
      },
      "action": {
        "type": "move",
        "destinationFolder": "Inbox/NE EDU Team"
      }
    },
    {
      "id": "u-of-rochester-routing",
      "enabled": true,
      "priority": 6,
      "conditions": {
        "isRead": true,
        "isPinned": false,
        "from": {
          "domains": ["@URMC.Rochester.edu"]
        }
      },
      "action": {
        "type": "move",
        "destinationFolder": "Inbox/Accounts/U of Rochester"
      }
    },
    {
      "id": "kevin-chin-routing",
      "enabled": true,
      "priority": 7,
      "conditions": {
        "isRead": true,
        "isPinned": false,
        "from": {
          "emails": ["kevin.chin@microsoft.com"]
        }
      },
      "action": {
        "type": "move",
        "destinationFolder": "Inbox/Kevin Chin"
      }
    },
    {
      "id": "u-of-newhaven-routing",
      "enabled": true,
      "priority": 8,
      "conditions": {
        "isRead": true,
        "isPinned": false,
        "from": {
          "domains": ["@newhaven.edu"]
        }
      },
      "action": {
        "type": "move",
        "destinationFolder": "Inbox/Accounts/U of NewHaven"
      }
    },
    {
      "id": "powerbi-sharepoint-delete-routing",
      "enabled": true,
      "priority": 9,
      "conditions": {
        "from": {
          "domains": ["@powerbi.com", "@sharepointonline.com"]
        }
      },
      "action": {
        "type": "move",
        "destinationFolder": "Delete"
      }
    },
    {
      "id": "bot-and-noreply-to-digest",
      "enabled": true,
      "priority": 2,
      "conditions": {
        "received": {
          "type": "relative",
          "last": {
            "value": 30,
            "unit": "days"
          }
        },
        "from": {
          "addressContainsAny": ["noreply", "no-reply", "bot", "notification"]
        }
      },
      "action": {
        "type": "move",
        "destinationFolder": "Inbox/Misc/Digest",
        "markRead": true
      }
    },
    {
      "id": "expense-mail-filing",
      "enabled": true,
      "priority": 3,
      "conditions": {
        "isRead": true,
        "subject": {
          "containsAny": ["invoice", "receipt", "expense", "reimbursement"]
        }
      },
      "action": {
        "type": "move",
        "destinationFolder": "Inbox/Expense"
      }
    },
    {
      "id": "security-alerts-routing",
      "enabled": true,
      "priority": 4,
      "conditions": {
        "subject": {
          "containsAny": ["alert", "security", "defender", "incident"]
        },
        "from": {
          "addressContainsAny": ["mssecurity-noreply", "azure-noreply", "s360-noreply"]
        }
      },
      "action": {
        "type": "move",
        "destinationFolder": "Inbox/Security Enablement",
        "markRead": false
      }
    },
    {
      "id": "old-read-inbox-to-archive",
      "enabled": true,
      "priority": 99,
      "conditions": {
        "isRead": true,
        "received": {
          "type": "relative",
          "olderThan": {
            "value": 14,
            "unit": "days"
          }
        },
        "currentFolder": "Inbox"
      },
      "action": {
        "type": "move",
        "destinationFolder": "Archive"
      }
    }
  ]
}
