{
  "name": "read-email-filing-rules",
  "enabled": true,
  "defaultAction": "none",
  "rules": [
    {
      "id": "rule-001",
      "enabled": true,
      "priority": 1,
      "conditions": {
        "isRead": true,
        "isPinned": false,
        "from": {
          "domains": ["@ct.gov"]
        }
      },
      "action": {
        "type": "move",
        "destinationFolder": "Inbox/Accounts/St of CT"
      }
    },
    {
